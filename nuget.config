<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      GitHub Packages NuGet feed for KyuzanInc.Turnkey.Sdk and any
      future KyuzanInc.Turnkey.* packages until they ship to nuget.org.
      Auth is required; see docs/development.md for the full setup
      (the 'dotnet nuget add source' command and a NuGet.Config snippet
      with packageSourceCredentials).
    -->
    <add key="github-kyuzan" value="https://nuget.pkg.github.com/KyuzanInc/index.json" protocolVersion="3" />
    <!--
      Local file feed for downstream consumers (e.g. peak-sdk-unity)
      to consume locally-packed .nupkg files before public NuGet
      publish. Operator: produce .nupkg with
        dotnet pack peak-sdk-csharp.sln -c Release -o ./local-feed
      then point downstream nuget.config at the absolute path.
    -->
    <add key="local-feed" value="./local-feed" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-kyuzan">
      <package pattern="KyuzanInc.Turnkey.*" />
    </packageSource>
    <packageSource key="local-feed">
      <package pattern="KyuzanInc.Peak.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
