<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Local file feed for downstream consumers (e.g. peak-sdk-unity)
      to consume locally-packed .nupkg files before public NuGet
      publish. Operator: produce .nupkg with
        dotnet pack peak-sdk-csharp.sln -c Release -o ./local-feed
      then point downstream nuget.config at the absolute path.
    -->
    <add key="local-feed" value="./local-feed" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local-feed">
      <package pattern="KyuzanInc.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
