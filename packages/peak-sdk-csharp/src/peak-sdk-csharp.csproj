<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      net8.0-windows enables DpapiSecureStorage. The TFM is silently ignored
      on non-Windows hosts; ISecureStorage.IsAvailable returns false there
      (see docs/security/storage-threat-model.md).
    -->
    <TargetFrameworks>netstandard2.1;net8.0;net8.0-windows</TargetFrameworks>
    <!--
      net8.0-windows multi-targeting requires the Windows targeting pack on
      non-Windows CI runners. EnableWindowsTargeting=true asks NuGet to pull
      the ref-pack instead of erroring out on ubuntu / macos.
    -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <RootNamespace>KyuzanInc.Peak.Sdk</RootNamespace>
    <AssemblyName>KyuzanInc.Peak.Sdk</AssemblyName>
    <!--
      The committed lock file pins the published Turnkey package for trusted
      release restores. Public PR CI uses a separate ignored lock file while
      compiling the checksum-pinned public Turnkey source project.
    -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <NuGetLockFilePath Condition="'$(TurnkeySourceProject)' != ''">$(BaseIntermediateOutputPath)turnkey-source.packages.lock.json</NuGetLockFilePath>

    <PackageId>KyuzanInc.Peak.Sdk</PackageId>
    <Version>1.0.0</Version>
    <Title>KyuzanInc.Peak.Sdk</Title>
    <Description>Peak embedded-wallet SDK for .NET. OTP login, account management, private key import/export. A generic-NET port of peak-sdk-unity by Kyuzan Inc.; semantic equivalent of the Unity public surface plus selected behaviour from peak-sdk-browser. Includes IStorage / ISecureStorage abstractions; secure storage backends live in KyuzanInc.Peak.Sdk.Unity (Unity) or KyuzanInc.Peak.Sdk (Windows DPAPI).</Description>
    <PackageTags>peak;wallet;turnkey;sdk;embedded-wallet;p256;otp</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="KyuzanInc.Turnkey.Sdk" Condition="'$(TurnkeySourceProject)' == ''" />
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>

  <ItemGroup Condition="'$(TurnkeySourceProject)' != ''">
    <ProjectReference Include="$(TurnkeySourceProject)" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.public.md" Pack="true" PackagePath="README.md" />
    <None Include="..\..\..\LICENSE" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="KyuzanInc.Peak.Sdk.Tests" />
  </ItemGroup>

</Project>
