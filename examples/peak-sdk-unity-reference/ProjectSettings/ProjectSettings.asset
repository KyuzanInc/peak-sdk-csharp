%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!129 &1
PlayerSettings:
  m_ObjectHideFlags: 0
  serializedVersion: 26
  productName: PeakSdkUnityReference
  companyName: Kyuzan Inc.
  applicationIdentifier:
    Standalone: com.kyuzan.peak.example
  # --- Load-bearing for the IL2CPP smoke (spec D11/§5.5) ---
  # apiCompatibilityLevel: 6 == .NET Standard 2.1 (so the netstandard2.1 SDK asset
  # + System.Text.Json/Microsoft.Extensions.* resolve). scriptingBackend 1 == IL2CPP.
  # managedStrippingLevel 1 == Low: the committed default so the IL2CPP build actually
  # exercises the UnityLinker. A Disabled (0) build strips nothing, so it would prove
  # nothing about AOT survival — the whole point of this smoke. link.xml preserves
  # BouncyCastle/Turnkey; the runner may raise to Medium(2)/High(3) and re-test.
  apiCompatibilityLevelPerPlatform: {}
  apiCompatibilityLevel: 6
  scriptingBackend:
    Standalone: 1
  il2cppCompilerConfiguration: {}
  managedStrippingLevel:
    Standalone: 1
  allowUnsafeCode: 0
